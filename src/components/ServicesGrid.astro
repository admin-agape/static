---
/**
 * Agape — ServicesGrid
 *
 * DESIGN.md §3.3.3 — iterates over the `services` content collection,
 * orders by the frontmatter `order` field, and renders one card per
 * service. No JS — pure Astro template + Tailwind utility classes.
 *
 * Icons are inline SVGs (Heroicons-style, 24x24 outline). This keeps
 * the zero-JS-at-idle goal (§2.1) and the §6.2.3 no-third-party posture
 * intact — no icon-font request, no icon CDN.
 *
 * Locale: title and summary come from the i18n catalog so the ES page
 * shows translated card content. The `bullets` array stays in English
 * for the demo (the catalog doesn't have bullet translations yet);
 * the bullets are hidden on Spanish pages and a `data-translation`
 * marker on the card flags them as missing-translation for handoff
 * review. Production handoff adds bullet translations to the catalog.
 *
 * Slug → catalog-key map: the content collection entries have stable
 * slugs (filename minus .md), which we map to catalog keys. Adding
 * a new service means: drop a .md file with a slug, add the slug
 * to SLUG_TO_KEY below, and add the catalog entries.
 */
import { getCollection } from 'astro:content';
import { detectLocale, useTranslations } from '~/i18n';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order,
);

const locale = detectLocale(Astro.url.pathname);
const translate = useTranslations(locale);
const isDraft = locale !== 'en';

// Map service slug (filename minus .md) → i18n catalog namespace.
// The catalog keys follow `service.<slug>.name` and `.summary`.
const SLUG_TO_KEY: Record<string, string> = {
  iop: 'iop',
  'individualized-counseling': 'individual',
  'anger-management': 'anger',
  'reiki-meditation': 'reiki',
};

// Inline Heroicons-style SVG paths for the four services. Keyed by the
// `icon` frontmatter field on each service .md file (DESIGN.md §3.3.3).
const iconPaths: Record<string, string> = {
  users: 'M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M8.5 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
  user: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
  heart: 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z',
  sparkles: 'M12 3l2.09 6.26L20 11l-5.91 1.74L12 19l-2.09-6.26L4 11l5.91-1.74L12 3zM19 3l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3zM5 16l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3z',
  fire: 'M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z',
};

const titleId = 'services-heading';

// Localized section heading + subhead (catalog keys).
// (No eyebrow above the heading — services.eyebrow doesn't exist in the
// en or es catalog, and the section opens straight into "Services" /
// "Servicios" with no transitional tag.)
const sectionHeading = translate('services.heading');
const sectionSubhead = translate('services.subhead');
---

<section
  id="services"
  aria-labelledby={titleId}
  class="bg-base-100 py-16 sm:py-20"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-prose">
      <h2
        id={titleId}
        class="text-3xl font-bold tracking-tight text-neutral sm:text-4xl"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {sectionHeading}
      </h2>
      <p
        class="mt-3 text-lg text-neutral/80"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {sectionSubhead}
      </p>
    </div>

    <ul
      class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4"
      role="list"
    >
      {services.map((service) => {
        const iconPath = iconPaths[service.data.icon] ?? iconPaths.heart;
        const slug = service.slug;
        const catalogKey = SLUG_TO_KEY[slug] ?? slug;
        // Localized title + summary when the catalog has the key.
        // Falls back to the content collection values for unknown slugs
        // (so a new service file isn't silently broken).
        const cardTitle = locale === 'en'
          ? service.data.title
          : translate(`service.${catalogKey}.name`);
        const cardSummary = locale === 'en'
          ? service.data.summary
          : translate(`service.${catalogKey}.summary`);
        const showBullets = locale === 'en' && service.data.bullets.length > 0;
        return (
          <li
            class:list={[
              'flex h-full flex-col rounded-soft border border-base-300 bg-base-200 p-6 shadow-sm transition-shadow hover:shadow-md',
              service.data.featured && 'ring-2 ring-primary ring-offset-2 ring-offset-base-100',
            ]}
          >
            <div
              class="inline-flex h-12 w-12 items-center justify-center rounded-soft bg-primary/10 text-primary"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPath} />
              </svg>
            </div>

            <h3
              class="mt-4 text-lg font-semibold text-neutral"
              data-translation={isDraft ? 'draft' : undefined}
            >
              {cardTitle}
            </h3>
            <p
              class="mt-2 text-sm text-neutral/80"
              data-translation={isDraft ? 'draft' : undefined}
            >
              {cardSummary}
            </p>

            {showBullets && (
              <ul class="mt-4 space-y-2 text-sm text-neutral/80" role="list">
                {service.data.bullets.map((bullet) => (
                  <li class="flex items-start gap-2">
                    <svg
                      class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            )}

            <p class="mt-auto pt-6 text-xs text-neutral/80">
              {/* Per G.17: this CTA jumps to the form card (id="contact-form"
                  in Contact.astro), not the section header (#contact). The
                  landing page surface is the message textarea whose
                  placeholder is "I'd like to learn more about..." — the
                  CTA copy ("Ask about [service]") and the placeholder copy
                  are now part of the same micro-flow:
                    "Ask about IOP" → land on form → placeholder reads
                    "I'd like to learn more about..." → user has a starting
                  sentence ready to type.

                  Visual uniformity: mt-auto pins this CTA to the bottom of
                  every card so the "Ask about X" link aligns horizontally
                  across the 4-column grid regardless of which services have
                  bullets. Cards are flex-col with h-full, so this absorbs
                  any leftover vertical space above. */}
              <a
                href="#contact-form"
                class="text-primary underline-offset-2 hover:underline"
                data-translation={isDraft ? 'draft' : undefined}
              >
                {translate('services.ctaAsk', { service: cardTitle })}
              </a>
            </p>
          </li>
        );
      })}
    </ul>

    {/* NJ DOT impaired-driver program — secondary CTA inside this
        section per §3.3.3 line 247. */}
    <div class="mt-12 rounded-soft border border-primary/30 bg-primary/5 p-6">
      <p
        class="text-sm font-semibold text-primary"
        data-translation={isDraft ? 'draft' : undefined}
      >
        NJ DOT impaired-driver program
      </p>
      <p
        class="mt-2 text-base text-neutral"
        data-translation={isDraft ? 'draft' : undefined}
      >
        We work with the New Jersey Department of Transportation on
        impaired-driver counseling. Call us to ask about scheduling.
      </p>
      <p class="mt-3">
        <a
          href="tel:+16092420086"
          class="inline-flex h-11 items-center justify-center rounded-soft bg-primary px-5 text-sm font-semibold text-primary-content"
        >
          Call (609) 242-0086
        </a>
      </p>
    </div>
  </div>
</section>
