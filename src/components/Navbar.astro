---
/**
 * Agape — Navbar
 *
 * Sticky top navigation bar (DESIGN.md §3.2 component hierarchy). Composed
 * of: brand mark, anchor links to the four primary sections, and a Call CTA
 * button.
 *
 * The whole bar is `sticky top-0` so the Call CTA is always on screen as
 * the user scrolls — it is the primary conversion target on every viewport.
 * There is no separate mobile-only floating CTA: the previous
 * StickyCallButton.astro approach caused jitter (CTA reflowing as the
 * scroll position changed) and a pulsing animation that distracted from
 * the content. The inline navbar CTA stays put, never pulses, and works
 * identically on mobile, tablet, and desktop.
 *
 * Accessibility:
 *   - Semantic <nav> + aria-label
 *   - aria-current="page" on the link matching the current hash route
 *   - Tap target ≥ 44px per WCAG 2.5.5 (mobile)
 *   - Focus-visible outline (defined in global.css) for keyboard users
 */

interface Props {
  /** Override the visible brand name in the navbar. */
  brandName?: string;
}

const { brandName = 'Agape Counseling Services' } = Astro.props;

// Anchor links driven by §3.1 (Page Model). Order matches reading order
// on mobile (primary nav, not buried under a hamburger). The `#faq`
// link is unconditional — the §3.3.8 FAQ section is required at launch
// and ships with placeholder entries, so the link is always meaningful.
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
  { href: '#legal', label: 'Legal' },
];

// Resolve the active link from the current URL hash (works on initial
// page load and on hashchange — pure CSS :target would not give us
// aria-current). Falls back to no-active state for the home anchor.
const currentHash = Astro.url.hash;
---

<header class="sticky top-0 z-40 w-full border-b border-base-300 bg-base-100/95 backdrop-blur supports-[backdrop-filter]:bg-base-100/80">
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8"
    aria-label="Primary"
  >
    {/* Brand mark + company name — DESIGN.md §3.5.1.1 (company-logo.svg is the
        "new Company Logo per user directive 2026-06-19") + §3.5.1.7.3.2 (Navbar
        wired to the brand logo on 2026-06-19 07:19 ET) + §3.5.1.12 (Monterro
        brand-font lock-in for the company name). The `<img>` is decorative
        (alt="" + aria-hidden="true") and the parent `<a>` carries the
        accessible name `aria-label="{brandName} — back to top"` — Lighthouse
        `link-name` audit flagged the missing label on narrow viewports before
        this fix. */}
    <a
      href="#top"
      class="flex items-center gap-2 font-semibold text-primary no-underline"
      aria-label={`${brandName} — back to top`}
    >
      <img src="/brand/company-logo.svg" alt="" width="32" height="32" class="h-8 w-8" aria-hidden="true" />
      {/* Brand-name span — G.22 system-font relaxation. The letter-spacing
          override remains to give the brand name visual distinction within
          the system stack; the font-family is no longer overridden because
          the §3.5.1.12 Montserrat-via-@fontsource architecture was removed. */}
      <span class="hidden text-base tracking-tight sm:inline" style="letter-spacing: -0.01em;">{brandName}</span>
    </a>

    {/* Primary nav links — visible on tablet and up. On mobile these
        collapse into the footer / inline above-the-fold section anchors
        to keep tap targets large and the top bar uncluttered. */}
    <ul class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'inline-flex h-10 items-center rounded-soft px-3 text-sm font-medium text-neutral transition-colors hover:bg-base-200 hover:text-primary',
              currentHash === link.href && 'text-primary',
            ]}
            aria-current={currentHash === link.href ? 'true' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    {/* Call CTA — primary conversion target, always rendered inline at
        the end of the sticky navbar. No mobile-only duplicate: a single
        inline button in the sticky bar stays put during scroll and never
        competes with the page content visually. */}
    <a
      href="tel:+16092420086"
      class="inline-flex h-10 items-center gap-2 rounded-soft bg-primary px-4 text-sm font-semibold text-white shadow-sm transition-transform hover:scale-[1.02] focus-visible:scale-[1.02] motion-reduce:transform-none"
      aria-label="Call Agape Counseling Services at (609) 242-0086"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="hidden sm:inline">(609) 242-0086</span>
      <span class="sm:hidden">Call</span>
    </a>
  </nav>
</header>