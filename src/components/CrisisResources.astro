---
/**
 * Agape — CrisisResources
 *
 * DESIGN.md §3.3.7 + §6.1 — crisis resources are NOT optional content.
 * They are core. The component renders the §6.1 crisis-line block as a
 * standalone section near the footer, AND a brief "In crisis?" link
 * above the fold is the responsibility of the Hero / Navbar layer.
 *
 * Visibility rules (binding, §6.1 + §6.8):
 *   - Crisis resources MUST appear in a dedicated section near the
 *     footer AND in the footer itself.
 *   - On mobile, the crisis block must be reachable in ≤ 2 taps from
 *     any scroll position.
 *   - The phrase "In crisis?" must appear as a visible link above the
 *     fold on every page state.
 *
 * Locale: all labels, descriptions, and supporting copy come from the
 * i18n catalog. The phone numbers themselves stay as-is (they're
 * identifiers, not translatable strings).
 */
import { detectLocale, useTranslations } from '~/i18n';

const locale = detectLocale(Astro.url.pathname);
const translate = useTranslations(locale);
const isDraft = locale !== 'en';
---

<section
  id="crisis"
  aria-labelledby="crisis-heading"
  class="border-y border-base-300 bg-base-100"
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <h2
      id="crisis-heading"
      class="text-lg font-bold uppercase tracking-wide text-neutral"
      data-translation={isDraft ? 'draft' : undefined}
    >
      {translate('crisis.heading')}
    </h2>
    <p
      class="mt-3 max-w-prose text-sm text-neutral/80"
      data-translation={isDraft ? 'draft' : undefined}
    >
      {translate('crisis.body')}
    </p>

    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {/* 911 / ER */}
      <div class="flex h-full flex-col rounded-soft border border-base-300 bg-base-200 p-4">
        <p
          class="text-sm font-semibold uppercase tracking-wide text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.911.label')}
        </p>
        <p
          class="mt-2 text-base font-medium text-neutral"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.911.detail')}
        </p>
        <p class="mt-auto pt-3">
          <a
            href="tel:911"
            class="inline-flex h-12 w-full items-center justify-center rounded-soft bg-primary px-4 text-base font-semibold text-primary-content"
          >
            Call 911
          </a>
        </p>
      </div>

      {/* 988 — Suicide & Crisis Lifeline */}
      <div class="flex h-full flex-col rounded-soft border border-base-300 bg-base-200 p-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-neutral/80">24/7</p>
        <p class="mt-2 text-base font-semibold text-neutral">988</p>
        <p
          class="mt-1 text-sm text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.988.label')}
        </p>
        <p
          class="mt-3 text-xs text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.988.detail')}
        </p>
        <p class="mt-auto pt-3">
          <a
            href="tel:988"
            class="inline-flex h-12 w-full items-center justify-center rounded-soft bg-primary px-4 text-base font-semibold text-primary-content"
          >
            Call 988
          </a>
        </p>
      </div>

      {/* NJ Hopeline */}
      <div class="flex h-full flex-col rounded-soft border border-base-300 bg-base-200 p-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-neutral/80">24/7 — NJ</p>
        <p class="mt-2 text-base font-semibold text-neutral">1-855-654-6735</p>
        <p
          class="mt-1 text-sm text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.hopeline.label')}
        </p>
        <p
          class="mt-3 text-xs text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('crisis.hopeline.detail')}
        </p>
        <p class="mt-auto pt-3">
          <a
            href="tel:18556546735"
            class="inline-flex h-12 w-full items-center justify-center rounded-soft bg-primary px-4 text-base font-semibold text-primary-content"
          >
            Call Hopeline
          </a>
        </p>
      </div>

      {/* ReachNJ (NJ-specific SUD access) */}
      <div class="flex h-full flex-col rounded-soft border border-base-300 bg-base-200 p-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-neutral/80">NJ residents</p>
        <p class="mt-2 text-base font-semibold text-neutral">1-844-732-2465</p>
        <p class="mt-1 text-sm text-neutral/80">ReachNJ</p>
        <p class="mt-3 text-xs text-neutral/80">
          NJ-specific SUD treatment access.
        </p>
        <p class="mt-auto pt-3">
          <a
            href="tel:18447322465"
            class="inline-flex h-12 w-full items-center justify-center rounded-soft bg-primary px-4 text-base font-semibold text-primary-content"
          >
            Call ReachNJ
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
