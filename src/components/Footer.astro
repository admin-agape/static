---
/**
 * Agape — Footer
 *
 * DESIGN.md §6 — every legal disclosure lives here. The Footer is the
 * "last layer" of the page but also the primary destination for
 * compliance review: this is where §6.2.4 (42 CFR Part 2 notice),
 * §6.3 (Privacy), §6.4 (Disclaimers), and §6.5 (Accessibility) are
 * always reachable in ≤ 2 taps from any viewport state (§6.8).
 *
 * All §6 text is currently rendered from the §6 templates in
 * DESIGN.md. Each block is annotated with an [ATTORNEY REVIEW PENDING]
 * comment so the client's attorney can find the right section to
 * sign off on without reading component logic.
 *
 * §3.5.1.7.4 #1 (Footer logo wiring, closed in G.20) — the Footer now
 * renders the canonical Brand Logo via the §3.5.1.3 <Logo /> component.
 * This closes the §3.5.1.4 usage-map row that had listed the Footer as
 * "informative, NOT decorative" pending the §3.5.1.3 component build.
 *
 * Phase 2: extract each block's content into a separate Markdown file
 * under src/content/footer/ so attorneys can edit copy without touching
 * component code. Deferred — out of Phase 1 scope.
 */
import Logo from '~/components/Logo.astro';

const currentYear = new Date().getFullYear();

// Contact info (DESIGN.md Appendix D — Contact & Hours)
const phone = '(609) 242-0086';
const phoneHref = 'tel:+16092420086';
const email = 'info@agapenj.org';
const address = '815 U.S. 9, Lanoka Harbor, NJ 08734';

// Hours of operation
const hours = 'Mon–Fri 9:00 AM – 9:00 PM';
const weekendHours = 'Sat–Sun by appointment only';

// External links — all `rel="noopener noreferrer"` for tabnabbing
// protection, all explicit `target="_blank"` only when warranted.
const facebookUrl = 'http://www.facebook.com/Agapenj.org/';
const googleReviewUrl =
  'https://www.google.com/search?q=agape+counseling+services+lanoka+harbor+nj';
---

<footer id="legal" class="mt-16 bg-base-200 text-neutral">
  {/* Footer brand row — §3.5.1.7.4 #1 closed in G.20. Renders the
      canonical Brand Logo via the §3.5.1.3 <Logo /> component, sized
      to match the navbar brand mark (size="md" = 32px). decorative={false}
      so screen readers announce "Agape Counseling Services" — there is no
      parent <a> providing the accessible name in the Footer. */}
  <div class="border-b border-base-300">
    <div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-6 sm:px-6 lg:px-8">
      <Logo variant="mark" size="md" />
      {/* Brand-name span — G.22 system-font relaxation. The letter-spacing
          override remains to give the brand name visual distinction within
          the system stack; the font-family override was removed when the
          @fontsource/montserrat dependency was uninstalled (G.22). */}
      <span class="text-base font-semibold text-neutral sm:text-lg" style="letter-spacing: -0.01em;">
        Agape Counseling Services
      </span>
    </div>
  </div>
  {/* Pre-footer: hours + contact + social link — the "what you see at
      a glance" summary. Always rendered above the legal blocks so
      visitors can find the phone number without scrolling to the
      bottom-most block. */}
  <div class="border-b border-base-300">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-3 sm:px-6 lg:px-8">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">
          Hours
        </h2>
        <p class="mt-2 text-base font-medium">{hours}</p>
        <p class="text-sm text-neutral/80">{weekendHours}</p>
      </div>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">
          Contact
        </h2>
        <p class="mt-2">
          <a href={phoneHref} class="text-base font-medium text-neutral underline-offset-2 hover:underline">
            {phone}
          </a>
        </p>
        <p>
          <a href={`mailto:${email}`} class="text-base text-neutral underline-offset-2 hover:underline">
            {email}
          </a>
        </p>
        <address class="mt-2 not-italic text-sm text-neutral/80">
          {address}
        </address>
      </div>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-primary">
          Connect
        </h2>
        <ul class="mt-2 space-y-2 text-base">
          <li>
            {/* §6.2.3 — Facebook link ONLY. No SDK, no Pixel, no embed.
                Visitor's browser hits Facebook only when they click,
                which is user-initiated and not a §6.2.1 re-disclosure
                surface. */}
            <a
              href={facebookUrl}
              rel="noopener noreferrer"
              class="text-neutral underline-offset-2 hover:underline"
            >
              Facebook
              <span class="ml-1 text-xs text-neutral/80" aria-hidden="true">↗</span>
            </a>
          </li>
          <li>
            <a
              href={googleReviewUrl}
              rel="noopener noreferrer"
              class="text-neutral underline-offset-2 hover:underline"
            >
              Google reviews
              <span class="ml-1 text-xs text-neutral/80" aria-hidden="true">↗</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Legal disclosures block — DESIGN.md §6.2.4, §6.3, §6.4, §6.5.
      Each block is in a `<details>` so mobile users can collapse to
      their interest without losing visibility — §6.8 requires these
      to be reachable in ≤ 2 taps, and `<details>` keeps them reachable
      from any scroll position. */}

  {/* §6.2.4 — 42 CFR Part 2 Notice */}
  {/* [ATTORNEY REVIEW PENDING] Final wording subject to client/attorney
      approval per DESIGN.md §6.2.4. Current text is the §6.2.4 template. */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span>42 CFR Part 2 Notice</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8">
      {/* [ATTORNEY REVIEW PENDING] §6.2.4 template text — final wording subject
          to attorney sign-off. The block is in `<details>` per §6.8 visibility
          rule; expand affordance is the explicit summary element. */}
      <p>
        Agape Counseling Services is required by <strong>42 CFR Part 2</strong>
        to protect the confidentiality of substance use disorder treatment
        records. Information that you provide through this website is
        <strong> not</strong> a substitute for clinical care and does not
        establish a treatment relationship. If you are seeking treatment,
        please call us at <a href={phoneHref}>{phone}</a>.
      </p>
    </div>
  </details>

  {/* §6.3 — Privacy Notice */}
  {/* [ATTORNEY REVIEW PENDING] Privacy notice text — DESIGN.md §6.3 requires
      client/attorney sign-off before public launch. The §6.3 template is
      rendered below with the required content elements enumerated in §6.3
      lines 1–7. */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span>Privacy notice</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      {/* [ATTORNEY REVIEW PENDING] §6.3 lines 1–7 — required content elements:
          (1) no tracking cookies; (2) form submissions go via Web3Forms; (3)
          no PHI/SUD info via contact form; (4) no selling/sharing; (5) analytics
          provider statement; (6) effective date; (7) privacy contact email. */}
      <p>
        This site does not use tracking cookies. We do not sell or share your
        information with third parties for marketing.
      </p>
      <p>
        Form submissions are sent via <a href="https://web3forms.com/" rel="noopener noreferrer" class="underline">Web3Forms</a>
        and stored per that provider's privacy policy. Please do not submit
        medical, substance-use, or other sensitive health information through
        this form — it is for general inquiries only.
      </p>
      <p>
        We use Cloudflare Web Analytics to count visits. This service is
        cookieless, does not profile visitors, and does not share data with
        third parties.
      </p>
      <p>
        Effective date: <time datetime="2026-06-19">June 19, 2026</time>.
        Privacy questions: <a href={`mailto:${email}`} class="underline">{email}</a>.
      </p>
    </div>
  </details>

  {/* §6.4 — General Disclaimers */}
  {/* [ATTORNEY REVIEW PENDING] §6.4 lines 1–5. Item #1 (EIN) requires client
      supply per DESIGN.md §4.1 #13 — currently placeholder shows
      "[EIN: PENDING]" until the client supplies the actual EIN. */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span>Disclaimers</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      <p>
        Agape is a 501(c)(3) nonprofit organization.{' '}
        {/* [ATTORNEY REVIEW PENDING] EIN — DESIGN.md §4.1 #13 BLOCKER. The
            placeholder will be replaced with the client's actual EIN once
            supplied. Until then, the disclosure line is incomplete but the
            component structure is complete and §6.4 is reachable per §6.8. */}
        <span class="font-semibold">[EIN: PENDING — client to provide per DESIGN.md §4.1 #13]</span>
      </p>
      <p>Outpatient counseling services are provided by licensed clinicians.</p>
      <p>This website does not establish a clinician–patient relationship.</p>
      <p>This website does not provide medical advice, diagnosis, or treatment.</p>
      <p class="pt-2 text-xs text-neutral/80">
        © {currentYear} Agape Counseling Services. All rights reserved.
      </p>
    </div>
  </details>

  {/* §6.5 — Accessibility Statement */}
  {/* [ATTORNEY REVIEW PENDING] §6.5 template text — final wording subject to
      attorney review. The text below is the §6.5 template verbatim. */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span>Accessibility</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      <p>
        Agape is committed to ensuring digital accessibility for people with
        disabilities. We continually improve the user experience for everyone
        and apply the relevant accessibility standards.
      </p>
      <p>
        If you encounter an accessibility barrier, please contact us at{' '}
        <a href={phoneHref} class="underline">{phone}</a> or{' '}
        <a href={`mailto:${email}`} class="underline">{email}</a>.
      </p>
      <p class="text-xs text-neutral/80">
        This site targets WCAG 2.1 AA conformance (DESIGN.md §5.4).
      </p>
    </div>
  </details>

  {/* Final attribution row — dev handoff provenance. Kept tiny so the
      §6 disclosures remain the visual focus of the footer. */}
  <div class="bg-base-300">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-1 px-4 py-4 text-xs text-neutral/80 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>
        Built on the open web. Source available under MIT.
      </p>
      <p>
        Astro 4 · Tailwind 3 · DaisyUI 4 · GitHub Pages
      </p>
    </div>
  </div>
</footer>