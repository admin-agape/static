---
/**
 * Agape — Footer
 *
 * DESIGN.md §6 — every legal disclosure lives here. The Footer is the
 * "last layer" of the page but also the primary destination for
 * compliance review: this is where §6.2.4 (42 CFR Part 2 notice),
 * §6.3 (Privacy), §6.4 (Disclaimers), and §6.5 (Accessibility) are
 * always reachable in ≤ 2 taps from any viewport state (§6.8).
 *
 * All §6 text is currently rendered from the §6 templates in
 * DESIGN.md. Each block is annotated with an [ATTORNEY REVIEW PENDING]
 * comment so the client's attorney can find the right section to
 * sign off on without reading component logic.
 *
 * §3.5.1.7.4 #1 (Footer logo wiring, closed in G.20) — the Footer now
 * renders the canonical Brand Logo via the §3.5.1.3 <Logo /> component.
 * This closes the §3.5.1.4 usage-map row that had listed the Footer as
 * "informative, NOT decorative" pending the §3.5.1.3 component build.
 *
 * Phase 2: extract each block's content into a separate Markdown file
 * under src/content/footer/ so attorneys can edit copy without touching
 * component code. Deferred — out of Phase 1 scope.
 */
import Logo from '~/components/Logo.astro';
import { detectLocale, useTranslations } from '~/i18n';

const currentYear = new Date().getFullYear();
const locale = detectLocale(Astro.url.pathname);
const translate = useTranslations(locale);
const isDraft = locale !== 'en';

// Contact info (DESIGN.md Appendix D — Contact & Hours)
const phone = '(609) 242-0086';
const phoneHref = 'tel:+16092420086';
const email = 'info@agapenj.org';
const address = '815 U.S. 9, Lanoka Harbor, NJ 08734';

// External links — all `rel="noopener noreferrer"` for tabnabbing
// protection, all explicit `target="_blank"` only when warranted.
const facebookUrl = 'http://www.facebook.com/Agapenj.org/';
const googleReviewUrl =
  'https://www.google.com/search?q=agape+counseling+services+lanoka+harbor+nj';
---

<footer id="legal" class="mt-16 bg-base-200 text-neutral">
  {/* Footer brand row — §3.5.1.7.4 #1 closed in G.20. Renders the
      canonical Brand Logo via the §3.5.1.3 <Logo /> component, sized
      to match the navbar brand mark (size="md" = 32px). decorative={false}
      so screen readers announce "Agape Counseling Services" — there is no
      parent <a> providing the accessible name in the Footer. */}
  <div class="border-b border-base-300">
    <div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-6 sm:px-6 lg:px-8">
      <Logo variant="mark" size="md" />
      {/* Brand-name span — G.22 system-font relaxation. The letter-spacing
          override remains to give the brand name visual distinction within
          the system stack; the font-family override was removed when the
          @fontsource/montserrat dependency was uninstalled (G.22). */}
      <span class="text-base font-semibold text-neutral sm:text-lg" style="letter-spacing: -0.01em;">
        Agape Counseling Services
      </span>
    </div>
  </div>
  {/* Pre-footer: hours + contact + social link — the "what you see at
      a glance" summary. Always rendered above the legal blocks so
      visitors can find the phone number without scrolling to the
      bottom-most block. */}
  <div class="border-b border-base-300">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-3 sm:px-6 lg:px-8">
      <div>
        <h2
          class="text-sm font-semibold uppercase tracking-wide text-primary"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('footer.hours.heading')}
        </h2>
        <p
          class="mt-2 text-base font-medium"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('footer.hours.weekday')}
        </p>
        <p
          class="text-sm text-neutral/80"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('footer.hours.weekend')}
        </p>
      </div>
      <div>
        <h2
          class="text-sm font-semibold uppercase tracking-wide text-primary"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('footer.contact.heading')}
        </h2>
        <p class="mt-2">
          <a href={phoneHref} class="text-base font-medium text-neutral underline-offset-2 hover:underline">
            {phone}
          </a>
        </p>
        <p>
          <a href={`mailto:${email}`} class="text-base text-neutral underline-offset-2 hover:underline">
            {email}
          </a>
        </p>
        <address class="mt-2 not-italic text-sm text-neutral/80">
          {address}
        </address>
      </div>
      <div>
        <h2
          class="text-sm font-semibold uppercase tracking-wide text-primary"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('footer.connect.heading')}
        </h2>
        <ul class="mt-2 space-y-2 text-base">
          <li>
            <a
              href={facebookUrl}
              rel="noopener noreferrer"
              class="text-neutral underline-offset-2 hover:underline"
              data-translation={isDraft ? 'draft' : undefined}
            >
              {translate('footer.connect.facebook')}
              <span class="ml-1 text-xs text-neutral/80" aria-hidden="true">↗</span>
            </a>
          </li>
          <li>
            <a
              href={googleReviewUrl}
              rel="noopener noreferrer"
              class="text-neutral underline-offset-2 hover:underline"
              data-translation={isDraft ? 'draft' : undefined}
            >
              {translate('footer.connect.googleReviews')}
              <span class="ml-1 text-xs text-neutral/80" aria-hidden="true">↗</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Legal disclosures block — DESIGN.md §6.2.4, §6.3, §6.4, §6.5.
      Each block is in a `<details>` so mobile users can collapse to
      their interest without losing visibility — §6.8 requires these
      to be reachable in ≤ 2 taps, and `<details>` keeps them reachable
      from any scroll position. */}

  {/* §6.2.4 — 42 CFR Part 2 Notice */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.part2')}</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8">
      <p data-translation={isDraft ? 'draft' : undefined} set:html={translate('footer.legal.part2Body', {
        part2: '<strong>42 CFR Part 2</strong>',
        not: '<strong>not</strong>',
        phone: `<a href="${phoneHref}">${phone}</a>`,
      })} />
    </div>
  </details>

  {/* §6.3 — Privacy Notice */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.privacy')}</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.privacyP1')}</p>
      <p data-translation={isDraft ? 'draft' : undefined} set:html={translate('footer.legal.privacyP2', {
        web3formsLink: '<a href="https://web3forms.com/" rel="noopener noreferrer" class="underline">Web3Forms</a>',
      })} />
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.privacyP3')}</p>
      <p data-translation={isDraft ? 'draft' : undefined} set:html={translate('footer.legal.privacyEffective', { date: '<time datetime="2026-06-19">June 19, 2026</time>' }) + ' ' + translate('footer.legal.privacyContact', { email: `<a href="mailto:${email}" class="underline">${email}</a>` })} />
    </div>
  </details>

  {/* §6.4 — General Disclaimers */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.disclaimers')}</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      <p>
        {translate('footer.legal.einLabel')}
        <span class="font-semibold">[EIN: PENDING — client to provide per DESIGN.md §4.1 #13]</span>
      </p>
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.disclaimerClinicians')}</p>
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.disclaimerNoRelationship')}</p>
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.disclaimerNoAdvice')}</p>
      <p
        class="pt-2 text-xs text-neutral/80"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {translate('footer.legal.disclaimerCopyright', { year: currentYear })}
      </p>
    </div>
  </details>

  {/* §6.5 — Accessibility Statement */}
  <details class="group border-b border-base-300">
    <summary class="mx-auto flex max-w-6xl cursor-pointer items-center justify-between px-4 py-4 text-sm font-semibold uppercase tracking-wide text-primary hover:bg-base-300 sm:px-6 lg:px-8">
      <span data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.accessibility')}</span>
      <span class="ml-2 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
    </summary>
    <div class="mx-auto max-w-6xl px-4 pb-6 text-sm leading-relaxed text-neutral/80 sm:px-6 lg:px-8 space-y-3">
      <p data-translation={isDraft ? 'draft' : undefined}>{translate('footer.legal.accessibilityBody')}</p>
      <p data-translation={isDraft ? 'draft' : undefined} set:html={translate('footer.legal.accessibilityContact', {
        phone: `<a href="${phoneHref}" class="underline">${phone}</a>`,
        email: `<a href="mailto:${email}" class="underline">${email}</a>`,
      })} />
      <p
        class="text-xs text-neutral/80"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {translate('footer.legal.accessibilityConformance')}
      </p>
    </div>
  </details>

  {/* Final attribution row — dev handoff provenance. Kept tiny so the
      §6 disclosures remain the visual focus of the footer. The theme
      toggle on the right flips between agape (light) and agape-dark
      (dark). The button is a no-JS fallback: if the script in
      BaseLayout hasn't run yet, the button still works because it
      has a real `aria-pressed` state and a label. The script
      enhances it with the localStorage persistence and the
      data-theme attribute flip. */}
  <div class="bg-base-300">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-2 px-4 py-4 text-xs text-neutral/80 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p data-translation={isDraft ? 'draft' : undefined}>
        {translate('footer.builtWith')}
      </p>
      <div class="flex items-center gap-3">
        <p>
          Astro 4 · Tailwind 3 · DaisyUI 4 · GitHub Pages
        </p>
        <button
          type="button"
          id="theme-toggle"
          aria-label="Toggle dark mode"
          aria-pressed="false"
          class="inline-flex h-8 items-center gap-1.5 rounded-soft border border-base-300 bg-base-100 px-2.5 text-xs font-semibold text-neutral transition-colors hover:bg-base-200"
        >
          <svg id="theme-toggle-icon-light" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
          <svg id="theme-toggle-icon-dark" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <span id="theme-toggle-label">Light</span>
        </button>
      </div>
    </div>
  </div>
</footer>