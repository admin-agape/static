---
/**
 * Agape — FAQ Component (DESIGN.md §3.3.8 + §10.3)
 *
 * Renders a semantically correct `<details>` / `<summary>` accordion. The
 * question/answer text comes from the i18n catalog so the EN and ES
 * pages render localized FAQ content. The `src/data/faq.json` file
 * still exists (validated against src/data/faq.schema.json) as the
 * canonical ID list — it provides the ORDER and IDs of the questions,
 * and the component maps each ID to the catalog keys (e.g.,
 * `faq-q-medicaid` → `faq.q.medicaid` + `faq.a.medicaid`).
 *
 * The data file is the structural contract; the catalog is the
 * content contract. This split lets the client edit copy in JSON
 * (one place per locale) without changing the schema, while still
 * being able to add/remove/reorder items via `faq.json`.
 *
 * Contract:
 *   - Required props: none. The data file + catalog ARE the contract.
 *   - Locale: detected from Astro.url.pathname via ~/i18n.
 *   - Empty-state: if items: [], renders a single <p> placeholder with
 *     the phone number — keeps §1.1 "lifeline" promise.
 *   - Accessibility: <details>/<summary> are first-class disclosure
 *     widgets, no ARIA scaffolding needed. <summary> wraps <h3> for
 *     heading-rotation navigation. Each <details> carries a stable
 *     id="faq-q-<n>" for deep links (e.g., agapenj.org/#faq-q-medicaid).
 *   - 0 KB JS: no executable <script> in the component body. The JSON-LD
 *     <script type="application/ld+json"> is a data block, not executable JS.
 *
 * Phase 2 use case: a /faq route via Astro content collections (the optional
 * `source` prop is the seam).
 */
import faqData from '~/data/faq.json';
import { detectLocale, useTranslations } from '~/i18n';

interface Props {
  /** Override the wrapping section id. Default: 'faq'. */
  id?: string;
  /** Optional heading override. Default: catalog key faq.heading. */
  heading?: string;
  /** Optional section classes override. Default: §3.3.8 calm, generous. */
  class?: string;
}

const locale = detectLocale(Astro.url.pathname);
const translate = useTranslations(locale);
const isDraft = locale !== 'en';

const {
  id = 'faq',
  heading = translate('faq.heading'),
  class: className = 'bg-base-100 py-16 sm:py-20',
} = Astro.props;

// Coerce to the typed shape. The build fails in CI if any item is invalid
// (npm run check:faq → scripts/check-faq.mjs); this is a runtime sanity
// check only — the schema is the real gate.
const items: { id: string }[] = Array.isArray(faqData?.items)
  ? (faqData.items as Array<{ id: string }>).filter((it) => it && typeof it.id === 'string')
  : [];

const hasItems = items.length > 0;

// Map a faq.json id (e.g., "faq-q-iop-length") to the catalog namespace
// (e.g., "iopLength"). The catalog uses camelCase keys; the JSON uses
// kebab-case slugs. We normalize by stripping the `faq-q-` prefix
// and converting kebab-case to camelCase. Falls back to the id when
// no catalog key exists (which then surfaces as the raw key, making
// the gap obvious in the rendered HTML).
function idToCatalogKey(id: string): string {
  const stripped = id.replace(/^faq-q-/, '');
  return stripped.replace(/-([a-z])/g, (_match, letter: string) => letter.toUpperCase());
}

// Localize the question + answer via the catalog. Falls back to the
// faq.json values when the catalog doesn't have a translation (the
// data file is the structural source of truth).
interface LocalizedItem {
  id: string;
  question: string;
  answer: string;
}
const localizedItems: LocalizedItem[] = items.map((item) => {
  const key = idToCatalogKey(item.id);
  if (locale === 'en') {
    // For EN, use the catalog (which mirrors the JSON values today).
    // This keeps a single source of truth for the EN copy.
    return {
      id: item.id,
      question: translate(`faq.q.${key}`),
      answer: translate(`faq.a.${key}`),
    };
  }
  // For ES, use the catalog. If a key is missing, the translate()
  // function returns the key itself, which surfaces the gap rather
  // than silently falling back to English.
  return {
    id: item.id,
    question: translate(`faq.q.${key}`),
    answer: translate(`faq.a.${key}`),
  };
});

// Build the JSON-LD payload up-front so the <script> tag in the template is
// a one-liner. mainEntity uses the localized questions + answers. We emit
// the localized FAQPage so search engines see the locale's content (not
// EN mixed into the ES page's structured data).
const jsonLdString = hasItems
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      inLanguage: locale,
      mainEntity: localizedItems.map((it) => ({
        '@type': 'Question',
        name: it.question,
        acceptedAnswer: { '@type': 'Answer', text: it.answer },
      })),
    })
  : '';
---

{/* The §10.3 emission contract — Astro hoists <script type="application/ld+json">
    into the document <head>. Emitted only when items.length > 0; we do NOT
    ship an empty FAQPage (that would be a thin-content spam signal). */}
{hasItems && (
  <script type="application/ld+json" set:html={jsonLdString} is:inline />
)}

<section id={id} aria-labelledby={`${id}-heading`} class={className}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2
      id={`${id}-heading`}
      class="text-3xl font-bold tracking-tight text-neutral sm:text-4xl"
      data-translation={isDraft ? 'draft' : undefined}
    >
      {heading}
    </h2>
    <p
      class="mt-3 text-base text-neutral/80"
      data-translation={isDraft ? 'draft' : undefined}
    >
      {translate('faq.intro')}
    </p>

    {hasItems ? (
      <div class="mt-8 space-y-4">
        {localizedItems.map((item) => (
          <details
            id={item.id}
            class="group rounded-soft border border-base-300 bg-base-200 transition-colors open:bg-base-100"
          >
            <summary
              class="flex cursor-pointer items-center justify-between gap-4 rounded-soft px-5 py-4 text-left text-base font-semibold text-neutral transition-colors hover:bg-base-300/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary sm:text-lg"
              style="min-height: 44px;"
            >
              <h3
                class="text-base font-semibold text-neutral sm:text-lg"
                data-translation={isDraft ? 'draft' : undefined}
              >
                {item.question}
              </h3>
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="h-5 w-5 shrink-0 text-primary transition-transform group-open:rotate-180"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-base text-neutral/80">
              <p data-translation={isDraft ? 'draft' : undefined}>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    ) : (
      <p class="mt-8 text-base text-neutral/80">
        No frequently asked questions yet. Call us at{' '}
        <a
          href="tel:+16092420086"
          class="font-semibold text-primary underline-offset-2 hover:underline"
        >
          (609) 242-0086
        </a>{' '}for answers.
      </p>
    )}
  </div>
</section>
