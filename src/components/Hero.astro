---
/**
 * Agape — Hero
 *
 * DESIGN.md §3.3.1 — the first thing visitors see. Mobile-first by design.
 * Carries the primary value proposition, a single Call CTA, and a single
 * form-CTA secondary. No modal popup (DESIGN.md Appendix F — modal removed
 * from legacy TSI site because it was hostile UX).
 *
 * Copy rules (§4.4):
 *   - Second-person, present tense
 *   - Grade 7 reading level
 *   - No "holistic", "journey", "transformative", "wellness"
 *   - Concrete verbs: talk, listen, schedule, call
 *
 * Locale: detected from Astro.url.pathname via ~/i18n. Spanish strings
 * are drafts and carry `data-translation="draft"` in the rendered HTML
 * so a reviewer can grep and replace them.
 *
 * The headline is configurable via props so the §4.1 Bucket 2 mission
 * statement approval can be dropped in without touching the component.
 */
import { detectLocale, useTranslations } from '~/i18n';

interface Props {
  /** Eyebrow above the headline. */
  eyebrow?: string;
  /** Main headline (H1). Should be one sentence, second-person. */
  headline?: string;
  /** Sub-headline — one or two short sentences. */
  subhead?: string;
  /** Hero illustration source. Optional — when omitted the hero is text-only. */
  imageSrc?: string;
  imageAlt?: string;
}

const locale = detectLocale(Astro.url.pathname);
const translate = useTranslations(locale);
const isDraft = locale !== 'en';

const {
  eyebrow = translate('hero.eyebrow'),
  headline = translate('hero.headline'),
  subhead = translate('hero.subhead'),
  imageSrc,
  imageAlt = '',
} = Astro.props;
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-gradient-to-b from-base-200 to-base-100"
>
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 sm:py-16 lg:grid-cols-5 lg:gap-12 lg:py-24">
    <div class="lg:col-span-3">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {eyebrow}
      </p>
      <h1
        class="text-3xl font-bold leading-tight text-neutral sm:text-4xl lg:text-5xl"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {headline}
      </h1>
      <p
        class="mt-4 max-w-prose text-lg text-neutral/80 sm:text-xl"
        data-translation={isDraft ? 'draft' : undefined}
      >
        {subhead}
      </p>

      {/* Primary CTAs — stacked on mobile, inline on tablet+. The Call
          CTA is the primary conversion (DESIGN.md §3.3.1 "the lifeline").
          The form CTA is secondary — for callers who prefer text. */}
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a
          href="tel:+16092420086"
          class="inline-flex h-14 items-center justify-center gap-3 rounded-soft bg-primary px-6 text-lg font-semibold text-primary-content shadow-md transition-transform hover:scale-[1.02] motion-reduce:transform-none"
          data-translation={isDraft ? 'draft' : undefined}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {translate('hero.ctaCall')}
        </a>
        <a
          href="#contact-form"
          class="inline-flex h-14 items-center justify-center gap-2 rounded-soft border-2 border-primary bg-transparent px-6 text-lg font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-content"
          data-translation={isDraft ? 'draft' : undefined}
        >
          {translate('hero.ctaMessage')}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      {/* Trust strip — short, factual, no marketing fluff. Per §4.4:
          prefer concrete verbs and Grade-7 reading level. */}
      <dl class="mt-10 grid max-w-md grid-cols-2 gap-6 text-sm">
        <div>
          <dt class="font-semibold text-neutral" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.sameWeek.label')}</dt>
          <dd class="mt-1 text-neutral/80" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.sameWeek.value')}</dd>
        </div>
        <div>
          <dt class="font-semibold text-neutral" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.bilingual.label')}</dt>
          <dd class="mt-1 text-neutral/80" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.bilingual.value')}</dd>
        </div>
        <div>
          <dt class="font-semibold text-neutral" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.medicaid.label')}</dt>
          <dd class="mt-1 text-neutral/80" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.medicaid.value')}</dd>
        </div>
        <div>
          <dt class="font-semibold text-neutral" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.confidential.label')}</dt>
          <dd class="mt-1 text-neutral/80" data-translation={isDraft ? 'draft' : undefined}>{translate('hero.stat.confidential.value')}</dd>
        </div>
      </dl>
    </div>

    {/* Right column — image or visual. Hidden when no imageSrc is supplied
        so the hero collapses cleanly on small viewports without awkward
        empty space. */}
    {imageSrc && (
      <div class="lg:col-span-2">
        <div class="aspect-square w-full overflow-hidden rounded-soft bg-base-200 shadow-lg">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="h-full w-full object-cover"
            loading="eager"
            decoding="async"
            width="600"
            height="600"
          />
        </div>
      </div>
    )}
  </div>
</section>
