---
/**
 * Agape — BaseLayout
 *
 * Single HTML shell for the entire site. Wraps every page so the head,
 * skip-link, navbar, footer, and the two Cloudflare third-party scripts
 * (Web Analytics beacon + Turnstile bootstrap) are configured exactly once.
 *
 * Compliance surface (DESIGN.md §6):
 *   - The two third-party scripts on this site are BOTH from Cloudflare:
 *       1. Cloudflare Web Analytics beacon (§6.2.3 — cookieless, no
 *          profiling, no consent banner). ~5KB, defer async.
 *       2. Cloudflare Turnstile bootstrap (§6.6 spam protection for
 *          ContactForm.astro — invisible widget). ~50KB, async defer,
 *          only loaded when PUBLIC_TURNSTILE_SITE_KEY is set.
 *     No GA, no Meta Pixel, no GTM, no Facebook SDK. The §2.1 "0 KB
 *     framework JS" goal is preserved (no Astro islands, no hydration).
 *   - If PUBLIC_CF_ANALYTICS_TOKEN or PUBLIC_TURNSTILE_SITE_KEY is unset
 *     (e.g., during local dev or before the client provisions them), the
 *     corresponding script is omitted entirely. The build never fails
 *     because of an unset credential.
 *   - The data-theme attribute activates the `agape` DaisyUI theme
 *     defined in tailwind.config.js (DESIGN.md §3.5).
 *   - JSON-LD is `MedicalClinic` per §10.2 (preferred for clinical
 *     practices). The §10.2.1 forbidden fields (`founder`, `employee`,
 *     `member`, `review`, `aggregateRating`, `ratingValue`,
 *     `reviewCount`) are explicitly absent.
 */
import '~/styles/global.css';
import Navbar from '~/components/Navbar.astro';
import Footer from '~/components/Footer.astro';
import CrisisResources from '~/components/CrisisResources.astro';
import SEO from '~/components/SEO.astro';
import { detectLocale, type Locale } from '~/i18n';

interface HreflangEntry {
  lang: Locale | 'x-default';
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  /** Override the canonical URL (default: site root + current path). */
  canonical?: string;
  /** Override the OG image URL (default: §10.1 fallback). */
  ogImage?: string;
  /** Hide CrisisResources inside <main>; some legacy flows may want to
   *  inject them higher up. Default: render inside main, above the fold
   *  on mobile (DESIGN.md §3.3.7 visibility rule). */
  suppressCrisisResources?: boolean;
  /** Override the locale detected from URL. Pass `'es'` from
   *  src/pages/es.astro to set <html lang="es"> and emit Spanish
   *  hreflang entries. Default: auto-detect from Astro.url.pathname. */
  locale?: Locale;
  /** hreflang alternates for SEO. The page that calls BaseLayout
   *  should pass the full set of (lang, absolute-URL) pairs including
   *  itself. Default: none (English-only page emits no hreflang). */
  hreflang?: HreflangEntry[];
}

const {
  title = 'Agape Counseling Services — Lanoka Harbor, NJ',
  description = 'Outpatient substance use disorder counseling in Lanoka Harbor, NJ. Intensive outpatient program, individualized counseling, anger management, reiki and meditation. Bilingual. Medicaid accepted. No wait list.',
  canonical,
  ogImage,
  suppressCrisisResources = false,
  locale: localeProp,
  hreflang = [],
} = Astro.props;

// Locale detection priority: explicit prop > URL pathname detection.
// The es.astro page passes locale="es" to set <html lang="es"> and
// ensure hreflang emission. Component-level locale (via Astro.url)
// still uses URL detection for consistency.
const locale: Locale = localeProp ?? detectLocale(Astro.url.pathname);

// Cloudflare Web Analytics — token is provisioned post-handoff by the
// client via .env / GitHub Actions secret. See DESIGN.md §6.2.3
// (cookieless, no visitor profiling, no consent banner required).
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// Cloudflare Turnstile — site key is provisioned post-handoff by the
// client via .env / GitHub Actions secret. Used by ContactForm.astro
// as the §6.6 spam-protection layer (invisible widget). When unset, the
// Turnstile widget and its bootstrap script are omitted entirely; the
// honeypot field in ContactForm.astro is the baseline spam gate.
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://agapenj.org';
// Build the canonical with the URL constructor — `site + Astro.url.pathname`
// concatenation produces a doubled path for demo builds because the
// per-client `site` is already tier-prefixed (e.g.,
// https://demo.mophe.us/agape/tier-1/) AND the build's `base` is also
// /agape/tier-1/, so `Astro.url.pathname` returns /agape/tier-1/. The
// naive concat would yield demo.mophe.us/agape/tier-1/agape/tier-1/.
// The URL constructor handles this correctly: the pathname is taken as
// an absolute path on the base URL, so the doubled-prefix is
// deduplicated and the result is just demo.mophe.us/agape/tier-1/.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl + '/').toString().replace(/\/$/, '') + '/';
// §10.1 — fallback to the canonical /og-default.jpg (1200×630, ≤ 200 KB).
const ogImageUrl = ogImage ?? `${siteUrl}/og-default.jpg`;
---

<!doctype html>
<html lang={locale} data-theme="agape">
  <head>
    {/*
      Theme bootstrap — runs as a bundled module loaded synchronously
      in the <head> to prevent a flash of the wrong theme (FOUC).
      Astro hoists this <script> tag to a separate file and emits
      <script type="module" src="..."> in the head. The module
      dependency on import.meta means the browser doesn't delay first
      paint waiting for the script.

      Three-tier resolution:
        1. localStorage 'agape-theme' = 'agape-dark' or 'agape' (explicit)
        2. prefers-color-scheme: dark → 'agape-dark' (only if no explicit)
        3. Default to 'agape' (light, declared on <html data-theme="agape">)

      Why this isn't `is:inline`: a strict CSP
      (script-src 'self' https://...) blocks inline scripts. The
      bundled form keeps the CSP clean (no 'unsafe-inline') and the
      page still resolves the theme before the first paint because
      module scripts block the parser until evaluated.

      The toggle handler is a separate <script> below — it can run
      after DOMContentLoaded since it only needs the toggle button,
      not the <html> element.
    */}
    <script>
      // Read this synchronously and set data-theme BEFORE the page
      // renders. The default is "agape" on the <html> element, so a
      // missed bootstrap (e.g., JS disabled) just shows the light theme.
      (function () {
        try {
          var stored = localStorage.getItem("agape-theme");
          var theme =
            stored === "agape-dark" || stored === "agape"
              ? stored
              : window.matchMedia &&
                  window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "agape-dark"
                : "agape";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          // localStorage or matchMedia blocked — fall through to default.
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* SEO.astro — DESIGN.md §10.1 emission contract. Single source of
        truth for title, description, canonical, OG, Twitter. */}
    <SEO
      title={title}
      description={description}
      canonicalURL={canonicalUrl}
      ogImage={ogImageUrl}
      locale={locale}
    />

    {/* hreflang alternates — emitted only when the page declares
        them. For the demo's two-locale setup, both index.astro and
        es.astro pass the full pair (en + es) so search engines see
        the alternates regardless of which page the crawler lands on.
        The page itself is omitted from the alternate set (the canonical
        is the same URL). */}
    {hreflang.map((entry) => (
      <link
        rel="alternate"
        hreflang={entry.lang}
        href={entry.href}
      />
    ))}

    {/* Favicon — Brand Logo per DESIGN.md §3.5.1.1 + §3.5.1.7.3.2. The
        `<link rel="icon">` points at /brand/company-logo.svg (the Brand
        Logo at #3a6faa, 1,674 bytes per the G.19 geometry swap) so the
        browser tab / address-bar / bookmarks icon matches the navbar
        brand mark. */}
    <link rel="icon" type="image/svg+xml" href="/brand/company-logo.svg" />

    {/* Apple touch icon — falls back to favicon.svg for now (Phase 2:
        generate a 180×180 PNG per §3.5.1.1). */}
    <link rel="apple-touch-icon" href="/brand/company-logo.svg" />

    {/* Cloudflare Web Analytics — first of two Cloudflare third-party
        scripts. Per DESIGN.md §6.2.3 this is cookieless, no visitor
        profiling, no consent banner required. Loaded deferred + async
        so it never blocks render. ~5KB. */}
    {cfToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfToken}"}`}
        is:inline
      />
    )}

    {/* Cloudflare Turnstile bootstrap script — second Cloudflare
        third-party script, used by ContactForm.astro for the §6.6
        spam-protection layer (invisible widget). The script auto-
        discovers `<div class="cf-turnstile" data-sitekey="...">`
        elements and renders the widget. ~50KB but loaded async +
        only when Turnstile is actually configured. */}
    {turnstileSiteKey && (
      <script
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        defer
        is:inline
      />
    )}

    {/* Schema.org MedicalClinic — DESIGN.md §10.2.
        `MedicalClinic` is the strongly preferred @type for this site
        (clinical practice providing outpatient SUD/IOP/counseling).
        Replaces the G.2/G.3 interim `ProfessionalService` type. All
        §10.2.1 forbidden fields (founder, employee, member, review,
        aggregateRating, ratingValue, reviewCount) are explicitly
        absent — the §3.3.5 testimonial ship-empty contract means
        emitting an aggregate rating with zero reviews would be a
        spam signal. No PHI, no testimonial text, no staff names —
        all within §6.2.1 42 CFR Part 2 boundaries. */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MedicalClinic',
      name: 'Agape Counseling Services',
      url: siteUrl,
      telephone: '+1-609-242-0086',
      email: 'info@agapenj.org',
      image: `${siteUrl}/og-default.jpg`,
      address: {
        '@type': 'PostalAddress',
        streetAddress: '815 U.S. 9',
        addressLocality: 'Lanoka Harbor',
        addressRegion: 'NJ',
        postalCode: '08734',
        addressCountry: 'US',
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '09:00',
          closes: '21:00',
        },
      ],
      priceRange: '$$',
      medicalSpecialty: 'https://schema.org/Psychiatric',
      areaServed: [
        { '@type': 'City', name: 'Lanoka Harbor' },
        { '@type': 'AdministrativeArea', name: 'Ocean County, NJ' },
      ],
    })} />
  </head>

  <body class="font-sans min-h-screen bg-base-100 text-neutral antialiased">
    {/* WCAG 2.1 AA §2.4.1 — bypass blocks: keyboard users can jump
        straight to main content. Visually hidden until focused. */}
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Navbar />

    <main id="main-content" tabindex="-1">
      {suppressCrisisResources ? <slot /> : (
        <>
          <slot />
          <CrisisResources />
        </>
      )}
    </main>

    <Footer />
  </body>
</html>

{/*
  Theme toggle — small bundler-friendly script that wires up the
  button rendered by Footer.astro. Reads/writes localStorage so the
  user's preference persists across visits. Listens for OS theme
  changes (only when the user hasn't made an explicit choice) so the
  site follows the system on machines that flip modes automatically.

  The script is bundled by Astro as a standard module (not is:inline)
  so it can tree-shake and minify. The bundled output is ~1KB.
*/}
<script>
  // Theme toggle handler — wires up the button rendered in Footer.astro.
  // Reads/writes localStorage so the user's preference persists. Listens
  // for OS theme changes only when the user hasn't made an explicit
  // choice (so explicit picks aren't overridden by an OS preference flip).
  //
  // The bundled module is ~1KB after minification. Runs after
  // DOMContentLoaded — the button is in the footer, so the script can
  // wait for the full DOM without any user-visible delay.
  function initThemeToggle() {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    var label = document.getElementById("theme-toggle-label");
    var iconLight = document.getElementById("theme-toggle-icon-light");
    var iconDark = document.getElementById("theme-toggle-icon-dark");
    if (!label || !iconLight || !iconDark) return;

    function currentTheme() {
      return document.documentElement.getAttribute("data-theme") || "agape";
    }

    function applyTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);
      var isDark = theme === "agape-dark";
      btn.setAttribute("aria-pressed", isDark ? "true" : "false");
      label.textContent = isDark ? "Dark" : "Light";
      // Show the icon for the mode you'd switch INTO (sun = "click to
      // go light", moon = "click to go dark"). This matches the
      // convention used by GitHub, Vercel, and most modern apps.
      iconLight.classList.toggle("hidden", isDark);
      iconDark.classList.toggle("hidden", !isDark);
    }

    // Initialize button state from the current theme (set by the
    // <head> bootstrap script).
    applyTheme(currentTheme());

    btn.addEventListener("click", function () {
      var next = currentTheme() === "agape-dark" ? "agape" : "agape-dark";
      applyTheme(next);
      try {
        localStorage.setItem("agape-theme", next);
      } catch (e) {
        // localStorage blocked — the in-page state still flips; the
        // choice just won't persist across visits.
      }
    });

    if (window.matchMedia) {
      var mq = window.matchMedia("(prefers-color-scheme: dark)");
      var listener = function (e) {
        try {
          if (localStorage.getItem("agape-theme")) return;
        } catch (err) {
          // ignore — fall through to OS-follow behavior
        }
        applyTheme(e.matches ? "agape-dark" : "agape");
      };
      if (mq.addEventListener) mq.addEventListener("change", listener);
      else if (mq.addListener) mq.addListener(listener);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initThemeToggle);
  } else {
    initThemeToggle();
  }
</script>
