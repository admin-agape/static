---
/**
 * Agape — index page
 *
 * DESIGN.md §3.1 — single long-scroll page composed of the sections
 * specified in §3.3. The page is wrapped by BaseLayout which supplies
 * the Navbar, Cloudflare Web Analytics beacon, and Footer.
 *
 * Tier gating (src/config/tiers.ts):
 *   - The kitchen-sink config (src/config/site.ts) flips every feature
 *     ON by default. Tier profile overlays flip the right flags OFF.
 *   - Tier 1 reads `site.features.newsletter` as `false` → no newsletter
 *     section, no /es/ page, no EN/ES link in the navbar. Tier 2/3 keep
 *     those on.
 *   - `import { site } from '~/config/site'` is a frozen merge of
 *     kitchen-sink + tier profile + build context. Reading
 *     `site.features.X` at the page level is the canonical gate.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import ServicesGrid from '~/components/ServicesGrid.astro';
import Testimonials from '~/components/Testimonials.astro';
import FAQ from '~/components/FAQ.astro';
import Newsletter from '~/components/Newsletter.astro';
import Contact from '~/components/Contact.astro';
import { site } from '~/config/site';
import { getCollection } from 'astro:content';

// Per the demo orchestrator (`dev/site/scripts/build-all-demos.mjs`),
// SITE_TIER is set to 1, 2, or 3 at build time. The hreflang URLs
// must point at the CURRENT tier, not a hardcoded tier — otherwise
// tier-3 (which is also bilingual) ships hreflang pointing at tier-2,
// which is wrong: a French/German/etc crawler landing on tier-3 sees
// "alternate en=es@2, es=es@2/es" and would never index tier-3 in the
// bilingual cluster. Use the SITE_TIER env var directly so every
// bilingual build (tier-2 and tier-3) self-references in its hreflang
// set. Falls back to '2' so local dev (no env var set) stays sensible.
const currentTier = process.env.SITE_TIER ?? '2';
const baseDemoUrl = `https://demo.mophe.us/agape/tier-${currentTier}/`;
---

<BaseLayout
  title="Agape Counseling Services — Outpatient SUD care in Lanoka Harbor, NJ"
  description="Outpatient substance use disorder counseling in Lanoka Harbor, NJ. Intensive outpatient program, individualized counseling, anger management, reiki and meditation. Bilingual. Medicaid accepted. No wait list."
  hreflang={site.features.bilingual ? [
    { lang: 'en', href: baseDemoUrl },
    { lang: 'es', href: `${baseDemoUrl}es/` },
  ] : []}
>
  <Hero />

  {/*
    §3.3.2 AccessBanner — bilingual / Medicaid / no-wait info.
    Replaces the legacy modal popup. Currently rendered inline because
    it's a single-section banner with copy from Appendix D. Will be
    extracted to AccessBanner.astro when §4.1 client approvals land.
  */}
  <section
    id="access"
    aria-labelledby="access-heading"
    class="border-y border-base-300 bg-secondary py-8 sm:py-10"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 id="access-heading" class="sr-only">
        Access information
      </h2>
      <p class="text-center text-base font-medium text-neutral sm:text-lg">
        We are now offering <strong>bilingual services</strong>, with the
        addition of taking <strong>Medicaid</strong>,{' '}
        <strong>no wait time</strong>, and options for uninsured individuals.
      </p>
      <p class="mt-3 text-center text-sm text-neutral/80">
        Give us a call today for more information:{' '}
        <a
          href="tel:+16092420086"
          class="font-semibold text-primary underline-offset-2 hover:underline"
        >
          (609) 242-0086
        </a>
      </p>
    </div>
  </section>

  <ServicesGrid />

  {/*
    §3.3.4 About / Mission — template copy pending §4.1 #6 client
    approval. Same template as Phase 1, will be extracted to
    About.astro when the final mission statement lands.
  */}
  <section
    id="about"
    aria-labelledby="about-heading"
    class="bg-base-200 py-16 sm:py-20"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-prose">
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">
          About Agape
        </p>
        <h2
          id="about-heading"
          class="mt-2 text-3xl font-bold tracking-tight text-neutral sm:text-4xl"
        >
          Counseling rooted in Ocean County since the 1990s.
        </h2>
        <div class="mt-6 space-y-4 text-base text-neutral/80">
          {/* [CLIENT TO REVIEW — DESIGN.md §4.1 #6] Mission statement pending
              client approval. The three §3.3.4 required copy elements are
              rendered below from the §3.3.4 template. */}
          <p>
            Agape Counseling Services is a certified 501(c)(3) nonprofit
            founded in the 1990s.
          </p>
          <p>
            We serve Ocean County, NJ from our Lanoka Harbor location.
          </p>
          <p>
            Our team helps people struggling with substance use disorder
            find and keep recovery through evidence-based outpatient care.
          </p>
        </div>
        <p class="mt-6 text-sm text-neutral/80">
          {/* [CLIENT TO REVIEW — DESIGN.md §4.1 #13] EIN to be added once
              supplied by the client. */}
          Agape is a 501(c)(3) nonprofit organization. EIN on file.
        </p>
      </div>
    </div>
  </section>

  <Testimonials />

  {/* §3.3.8 FAQ section — required at launch (per the §3.3.8 value prop:
      "free information that helps 95% of users"). Sits between
      Testimonials and Contact — the natural reading order (peer
      stories → questions → take action). */}
  <FAQ />

  {site.features.newsletter && <Newsletter />}

  {/*
    §3.3.x Tier-3 feature surface — blog. The blog teaser is the
    headline differentiator between the kitchen-sink tier (3) and
    tier 2: long-form thought leadership content for SEO. The teaser
    links to the full feature at /blog/.

    Note: a multi-location teaser used to live next to the blog teaser.
    Agape is a single-location practice (815 U.S. 9, Lanoka Harbor, NJ)
    so the multi-location functionality has been removed from this
    project entirely — see src/content/config.ts for the historical
    note and the rationale. Do not re-add a locations teaser without
    also re-evaluating the tier profile and the company switcher
    marketing copy (dev/site/demos/companies.json).

    Tier gating: the block reads site.features.blog — when the flag is
    off (tier 1 / tier 2), the block is omitted entirely. The
    orchestrator's tier cleanup also deletes the dist/<client>/tier-N/
    blog/ directory on lower tiers so the URL 404s.
  */}
  {site.features.blog && (
    <section class="bg-base-200 py-12 sm:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <a
          href="/blog/"
          class="group flex h-full flex-col rounded-soft border border-base-300 bg-base-100 p-6 shadow-sm transition-shadow hover:shadow-md"
        >
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">
            Insights from the team
          </p>
          <h2 class="mt-2 text-2xl font-semibold text-neutral">
            Read the blog
            <span aria-hidden="true" class="ml-1 transition-transform group-hover:translate-x-1">→</span>
          </h2>
          <p class="mt-3 text-base text-neutral/80">
            Practical guides on IOP, family support, 42 CFR Part 2, and
            navigating recovery in Ocean County.
          </p>
          <p class="mt-auto pt-4 text-sm text-neutral/80">
            <span class="text-primary underline-offset-2 group-hover:underline">
              Browse all posts
            </span>
          </p>
        </a>
      </div>
    </section>
  )}

  <Contact />
</BaseLayout>