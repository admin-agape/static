---
/**
 * Agape — Blog index (Tier 3+ feature).
 *
 * DESIGN.md §3.3 — long-form content for SEO and thought leadership.
 * Lists all blog posts in the `blog` content collection, sorted
 * newest-first. The page is gated on `site.features.blog === true`;
 * on tiers 1 and 2 the orchestrator's cleanup step deletes the
 * generated dist/<client>/tier-N/blog/ directory so the URL 404s.
 *
 * Per-post cards link to /blog/[slug]/. The RSS feed lives at
 * /blog/rss.xml and is auto-generated by src/pages/blog/rss.xml.ts.
 *
 * Note on `<main>`: BaseLayout already wraps the slot in
 * <main id="main-content">, so this page must NOT add another one
 * (otherwise the rendered HTML gets a nested <main> which breaks
 * the skip-link target and screen-reader landmark mapping).
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/config/site';
import { getCollection } from 'astro:content';

const showBlog = site.features.blog === true;
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);

// Defensive guard — matches the es.astro pattern. Astro's static
// build always emits /blog/index.html regardless of feature flags.
// The orchestrator deletes the directory for tiers 1 and 2, so this
// page is unreachable there; the gate below makes the page render
// a "feature not available in this tier" message if a build is run
// with blog=false and the file is still present.
---
{
  showBlog ? (
    <BaseLayout
      title="Insights from Agape — recovery, family support, and Ocean County resources"
      description="Long-form articles on outpatient substance use disorder treatment, family support, 42 CFR Part 2 privacy, and navigating recovery in Ocean County, NJ."
      locale="en"
    >
      <section class="bg-gradient-to-b from-base-200 to-base-100">
        <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">Insights</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-neutral sm:text-4xl">
            Notes from the clinical team
          </h1>
          <p class="mt-3 text-lg text-neutral/80">
            Practical guides on recovery, family support, and navigating
            treatment in Ocean County. Written by the Agape clinical team
            — no marketing copy, no filler.
          </p>
          <p class="mt-6 text-sm text-neutral/80">
            <a href="rss.xml" class="text-primary underline-offset-2 hover:underline">
              Subscribe via RSS
            </a>
          </p>
        </div>
      </section>

      <section class="bg-base-100 py-12 sm:py-16">
        <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
          <ul class="space-y-10" role="list">
            {posts.map((post) => (
              <li class="rounded-soft border border-base-300 bg-base-200 p-6 shadow-sm transition-shadow hover:shadow-md">
                <p class="text-xs font-mono uppercase tracking-wide text-neutral/80">
                  <time datetime={post.data.publishedAt}>
                    {new Date(post.data.publishedAt).toLocaleDateString('en-US', {
                      year: 'numeric', month: 'long', day: 'numeric',
                    })}
                  </time>
                  <span aria-hidden="true"> · </span>
                  <span>{post.data.readingMinutes} min read</span>
                </p>
                <h2 class="mt-2 text-2xl font-semibold text-neutral">
                  <a
                    href={`/blog/${post.slug}/`}
                    class="text-neutral no-underline hover:text-primary"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="mt-3 text-base text-neutral/80">{post.data.summary}</p>
                {post.data.tags.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-2" role="list">
                    {post.data.tags.map((tag) => (
                      <li class="inline-flex items-center rounded-full bg-base-300 px-2.5 py-0.5 text-xs font-medium text-neutral">
                        {tag}
                      </li>
                    ))}
                  </ul>
                )}
                <p class="mt-4">
                  <a
                    href={`/blog/${post.slug}/`}
                    class="text-primary underline-offset-2 hover:underline"
                  >
                    Read more →
                  </a>
                </p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="border-t border-base-300 bg-base-200 py-10">
        <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
          <p class="text-sm text-neutral/80">
            Have a topic you would like us to cover? Call us at
            {' '}
            <a href="tel:+16092420086" class="text-primary underline-offset-2 hover:underline">(609) 242-0086</a>
            {' '}or send a message — we read every suggestion.
          </p>
        </div>
      </section>
    </BaseLayout>
  ) : (
    <BaseLayout title="Blog not available — Agape Counseling Services">
      <section class="bg-base-200 py-16 sm:py-20">
        <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary">Not available</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-neutral sm:text-4xl">
            The blog is not included in this tier.
          </h1>
          <p class="mt-3 text-base text-neutral/80">
            The blog / insights section is part of Tier 3 (Premium).
            Call us at
            {' '}
            <a href="tel:+16092420086" class="text-primary underline">(609) 242-0086</a>
            {' '}and we will be happy to answer questions on the phone.
          </p>
          <p class="mt-3 text-base text-neutral/80">
            <a href=".." class="text-primary underline">Back to home</a>
          </p>
        </div>
      </section>
    </BaseLayout>
  )
}