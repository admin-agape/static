---
/**
 * Agape — Blog post detail (Tier 3+ feature).
 *
 * Dynamic route: /blog/[slug]/ — generated from the `blog` content
 * collection. getStaticPaths() emits one static page per post; the
 * page body renders the markdown content via Astro's <Content />
 * component (which compiles MD → HTML at build time, zero runtime JS).
 *
 * Tier gating matches /blog/index.astro: gated on
 * site.features.blog, with the orchestrator cleaning up the dist
 * output for tiers 1 + 2.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/config/site';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const showBlog = site.features.blog === true;
const seo = post.data.seo;
---
{
  showBlog ? (
    <BaseLayout
      title={seo?.title ?? `${post.data.title} — Agape Counseling Services`}
      description={seo?.description ?? post.data.summary}
      ogImage={seo?.ogImage}
      locale="en"
    >
<article class="bg-base-100">
        <header class="bg-gradient-to-b from-base-200 to-base-100">
          <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
            <p class="text-sm font-semibold uppercase tracking-wide text-primary">
              <a href="/blog/" class="text-primary no-underline hover:underline">← All insights</a>
            </p>
            <h1 class="mt-4 text-3xl font-bold tracking-tight text-neutral sm:text-4xl">
              {post.data.title}
            </h1>
            <p class="mt-3 text-lg text-neutral/80">{post.data.summary}</p>
            <p class="mt-6 text-sm text-neutral/80">
              <time datetime={post.data.publishedAt}>
                {new Date(post.data.publishedAt).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'long', day: 'numeric',
                })}
              </time>
              <span aria-hidden="true"> · </span>
              <span>{post.data.author}</span>
              <span aria-hidden="true"> · </span>
              <span>{post.data.readingMinutes} min read</span>
            </p>
          </div>
        </header>

        <div class="prose prose-neutral mx-auto max-w-3xl px-4 py-12 sm:py-16 lg:px-8">
          <Content />
        </div>

        <footer class="border-t border-base-300 bg-base-200 py-10">
          <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
            <p class="text-base text-neutral">
              Need help now? Call us at
              {' '}
              <a href="tel:+16092420086" class="text-primary underline-offset-2 hover:underline">(609) 242-0086</a>
              {' '}— confidential, free intake call.
            </p>
            <p class="mt-4">
              <a href="/blog/" class="text-primary underline-offset-2 hover:underline">
                ← All insights
              </a>
            </p>
          </div>
        </footer>
      </article>
    </BaseLayout>
  ) : (
    <BaseLayout title="Blog not available — Agape Counseling Services">
      <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">Not available</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-neutral sm:text-4xl">
          The blog is not included in this tier.
        </h1>
        <p class="mt-3 text-base text-neutral/80">
          Call us at
          {' '}
          <a href="tel:+16092420086" class="text-primary underline">(609) 242-0086</a>.
        </p>
        <p class="mt-3 text-base text-neutral/80">
          <a href="../.." class="text-primary underline">Back to home</a>
        </p>
      </section>
    </BaseLayout>
  )
}

<style is:global>
  /* Minimal typography for the post body — extends Tailwind's prose
     plugin defaults with sensible spacing for this site. No external
     dependencies; the typography is opinionated but small. */
  .prose h2 {
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.25;
    color: #1c2530;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: #1c2530;
  }
  .prose p {
    margin-top: 1rem;
    margin-bottom: 1rem;
    line-height: 1.7;
    color: #1c2530;
  }
  .prose a {
    color: #3a6faa;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    text-decoration-thickness: 2px;
  }
  .prose ul {
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }
  .prose li {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
    line-height: 1.6;
  }
  .prose strong {
    font-weight: 600;
    color: #1c2530;
  }
  .prose blockquote {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid #3a6faa;
    color: #1c2530;
    font-style: italic;
  }
  .prose code {
    background-color: rgba(15, 23, 42, 0.06);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9em;
  }
</style>