{
  "name": "agape",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agape Counseling Services — static rebuild (Astro 4 + Tailwind 3 + DaisyUI 4, hosted on GitHub Pages)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run check:faq && npm run check:logo-size && astro build",
    "preview": "astro preview",
