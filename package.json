    "daisyui": "^4.12.24",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "sharp": "^0.35.1",
    "svgo": "^4.0.1",
    "typescript": "^5.6.3"
  }
}
