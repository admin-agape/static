# Mopheus Code × Build-a-Bot — site-side env (for Cloudflare Pages Functions)
#
# Set these in the Cloudflare Pages dashboard under
# Settings → Environment variables. Do NOT commit real values.
#
# See `../_shared/mopheus-code-integration.mjs` for the verification flow.

# Site slug — stable across domain changes. The same value is in the
# promo URL Mopheus Code hands you. build-a-bot verifies this.
MOPHEUS_CODE_CLIENT_SLUG=agape

# Canonical URL of THIS site. Must match the `site_url` in the promo URL.
MOPHEUS_CODE_SITE_URL=https://agapenj.org

# ── RS256 public key (PRIMARY path, lightning-fast cold start) ──────────────
# The dev-side signing keypair is published at
# https://mophe.us/.well-known/mopheus-code-promo.pub. To bake it into
# the site (so the Worker never has to fetch it at request time),
# drop the public key PEM here:
MOPHEUS_CODE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8...
-----END PUBLIC KEY-----"

# The kid (key id) of the inline PEM. The verify flow uses this to
# detect a stale inline PEM and auto-fetch the current key from the
# fallback URL. Compute it by running `scripts/generate-promo-keypair.ts`
# — the kid is printed in the next-steps block.
#
# If unset, the verify flow computes the kid from MOPHEUS_CODE_PUBLIC_KEY
# at request time (a few ms extra per request until the first miss).
MOPHEUS_CODE_PUBLIC_KEY_ID=a1b2c3d4e5f6g7h8

# ── RS256 public key (FALLBACK path, on key rotation) ──────────────────────
# If the inline PEM's kid doesn't match the JWT's kid (or the inline
# PEM is missing entirely), the site fetches the current key from
# this URL and caches it in memory by kid for an hour. Auto-recovers
# when the dev rotates the keypair — no redeploy needed.
#
# Default if unset: https://mophe.us/.well-known/mopheus-code-promo.pub
# Set to empty string to DISABLE the fallback path entirely (kid
# mismatch then becomes a hard failure — sites don't auto-recover).
MOPHEUS_CODE_PUBLIC_KEY_FALLBACK_URL=https://mophe.us/.well-known/mopheus-code-promo.pub
