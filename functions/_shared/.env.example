# Mopheus Code × Build-a-Bot — site-side env (for Cloudflare Pages Functions)
#
# Set these in the Cloudflare Pages dashboard under
# Settings → Environment variables. Do NOT commit real values.
#
# See `../_shared/mopheus-code-integration.mjs` for the verification flow.

# Site slug — stable across domain changes. The same value is in the
# promo URL Mopheus Code hands you. build-a-bot verifies this.
MOPHEUS_CODE_CLIENT_SLUG=agape

# Canonical URL of THIS site. Must match the `site_url` in the promo URL.
MOPHEUS_CODE_SITE_URL=https://agapenj.org

# RS256 public key. Mopheus Code publishes the matching private key
# and uses it to sign promo URLs. Drop the public key PEM here (or
# fetch it from `https://mophe.us/.well-known/mopheus-code-promo.pub`
# at boot — see the alternative pattern below).
MOPHEUS_CODE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8...
-----END PUBLIC KEY-----"

# Optional — static bearer for testing access BEFORE the RS256 flow
# is wired. Leave EMPTY in production.
#
# When set: any request whose Authorization header matches this string
# is accepted as valid auth.
# When empty: only requests with a valid X-Mopheus-Code-Promo header
# AND a matching RS256-HKDF bearer are accepted.
MOPHEUS_CODE_DEMO_BEARER=

# ─────────────────────────────────────────────────────────────────────
# Alternative: fetch the public key from the canonical URL at boot
# instead of hard-coding it in env. To switch, edit
# `functions/api/blog/posts.ts` to fetch the key in `envToConfig`
# instead of reading `env.MOPHEUS_CODE_PUBLIC_KEY`. Key rotation is
# then operator-driven; you don't need to redeploy when Mopheus Code
# rotates the keypair.
#
#   const res = await fetch('https://mophe.us/.well-known/mopheus-code-promo.pub');
#   const pem = await res.text();
#
# The drop-in module's `verifyBearer` accepts any string for
# `publicKeyPem`, so this swap is one line.
# ─────────────────────────────────────────────────────────────────────
